# 缤纷汇内置 MCP 共享配置（复制为 .env 后填写）
# 开发：binfenhui-switch/mcp/.env
# 安装后：~/.Claude/mcp/.env 或在桌面端 MCP 设置 → 编辑共享配置

# Shopee Open API
SHOPEE_ENVIRONMENT=https://openplatform.shopee.cn
SHOPEE_PARTNER_ID=
# 须为开放平台提供的 shpk 开头密钥，勿填 hex 转码值
SHOPEE_PARTNER_KEY=

# Redis（Shopee + TikTok 共用）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# Shopee 读 API 缓存 → shopee:api:{main_id}:{shop_id}:*
SHOPEE_CACHE_ENABLED=1
SHOPEE_CACHE_DEFAULT_TTL=300

# TikTok 读 API 缓存 → tiktok:api:{app_key}:{shop_id}:*
TIKTOK_CACHE_ENABLED=1
TIKTOK_CACHE_DEFAULT_TTL=300
# 全店商品快照 TTL（0=不过期）TIKTOK_PRODUCTS_TTL=86400

# 马帮 ERP
MABANG_APPKEY=
MABANG_SECRET=

# Hermes / Honcho（可选，也可在桌面端 设置 → Hermes 写入 ~/.Claude/settings.json）
# BINFENHUI_HERMES_FEATURES=1
# BINFENHUI_SESSIONS_YIELD_TOOL=0
# HONCHO_API_KEY=
# HONCHO_WORKSPACE_ID=
# HONCHO_USER_PEER_ID=
# HONCHO_AI_PEER_ID=binfenhui
# HONCHO_BASE_URL=https://api.honcho.dev

# Nano Banana / Gemini CLI（内置技能 nano-banana，图像生成）
GEMINI_API_KEY=
# 与 GEMINI_API_KEY 等价，nanobanana 扩展也会读取：
# NANOBANANA_GEMINI_API_KEY=
# NANOBANANA_MODEL=gemini-3-pro-image-preview

# TikHub — TikTok 红人建联 MCP（tikhub-kol-mcp）
TIKHUB_API_KEY=

# TikTok Shop Open API
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_APP_LABEL=default
TIKTOK_ENVIRONMENT=live
TIKTOK_SDK_ROOT=
