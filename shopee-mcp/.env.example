# Shopee Open API（必填）
# sandbox | live | china | brazil，或完整域名/基址
# 中国跨境卖家平台：https://openplatform.shopee.cn（也可用 china）
SHOPEE_ENVIRONMENT=https://openplatform.shopee.cn
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# Redis（token、API 响应缓存、商品物化视图）
REDIS_HOST=100.90.207.29
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# API 响应自动缓存（只读 get/list/check/search）
SHOPEE_CACHE_ENABLED=1
SHOPEE_CACHE_DEFAULT_TTL=300
SHOPEE_CACHE_MAX_BYTES=2097152
SHOPEE_CACHE_META=1

# 马帮 ERP gwapi v2（库存查询 mabang_stock_get_stock_quantity）
MABANG_APPKEY=
MABANG_SECRET=
# MABANG_API_BASE=https://gwapi.mabangerp.com/api/v2
