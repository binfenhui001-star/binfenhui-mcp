{
  "name": "shopee-mcp",
  "version": "1.0.0",
  "description": "MCP server for Shopee Open API (built on @congminh1254/shopee-sdk)",
  "type": "module",
  "main": "./dist/mcp-server.js",
  "bin": {
    "shopee-sdk-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "node scripts/generate-sdk-tool-metadata.mjs && node scripts/audit-sdk-params.mjs && tsc",
    "test": "bun test src/",
    "generate:metadata": "node scripts/generate-sdk-tool-metadata.mjs",
    "start": "node --env-file=.env dist/mcp-server.js",
    "mcp:stdio": "node --env-file=.env dist/mcp-server.js",
    "redis:tokens": "node --env-file=.env scripts/list-redis-tokens.mjs",
    "tools:count": "npm run build && node scripts/count-sdk-tools.mjs",
    "dev": "tsc --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@congminh1254/shopee-sdk": "^1.6.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "ioredis": "^5.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0"
  }
}
