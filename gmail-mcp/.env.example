# Gmail MCP（OAuth 与令牌目录，默认 ~/.gmail-mcp/）
# MCP_CONFIG_DIR=~/.gmail-mcp
# GMAIL_OAUTH_PATH=
# GMAIL_CREDENTIALS_PATH=
# CLIENT_ID=
# CLIENT_SECRET=
# REFRESH_TOKEN=
# Streamable HTTP port for stdio mode (builtin default PORT=0 = OS-assigned; package default 3000 often conflicts)
# PORT=0
# OAuth callback port for `npx @shinzolabs/gmail-mcp auth` only:
# GMAIL_MCP_HTTP_PORT=38472
# AUTH_SERVER_PORT=38472
# TELEMETRY_ENABLED=0
