# TikTok Shop Open API（默认应用）
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_APP_LABEL=default
# sandbox | live（默认 live）
TIKTOK_ENVIRONMENT=live

# OAuth（卖家授权）
TIKTOK_REDIRECT_URI=https://your-app/callback/tiktok

# 第二个应用（后缀名 US 可改成任意标识）
# TIKTOK_APP_LABEL_US=us
# TIKTOK_APP_KEY_US=
# TIKTOK_APP_SECRET_US=
# TIKTOK_REDIRECT_URI_US=https://your-app/callback/tiktok-us

# 或 JSON 一次配置多个
# TIKTOK_APPS=[{"label":"us","app_key":"...","app_secret":"..."}]
# TIKTOK_DEFAULT_APP_LABEL=default
# TIKTOK_SERVICE_ID=
# TIKTOK_AUTH_URL_MODE=oauth
# TIKTOK_AUTH_HOST=https://auth.tiktok-shops.com

# SDK 已随 Git 提交在 vendor/nodejs_sdk，克隆后 npm run build 即可
# 仅在外部 SDK 路径覆盖时使用：
# TIKTOK_SDK_ROOT=/path/to/nodejs_sdk

# Redis（店铺 access_token）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# lazy（默认）| full
TIKTOK_MCP_REGISTER_MODE=lazy

# 读 API 自动缓存（与 Shopee SHOPEE_CACHE_* 类似）
TIKTOK_CACHE_ENABLED=1
TIKTOK_CACHE_DEFAULT_TTL=300
# TIKTOK_PRODUCTS_TTL=86400
# TIKTOK_SYNC_PRODUCTS_TOOL=tiktok_product_v202502_products_search_post
