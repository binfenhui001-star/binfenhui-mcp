{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "index.ts",
    "api.ts",
    "api/**/*.ts",
    "client/**/*.ts",
    "model/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
