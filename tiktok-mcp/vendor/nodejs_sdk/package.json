{
  "name": "tiktok-shop-node-sdk",
  "version": "1.0.0",
  "description": "TikTok Shop Open API Node.js SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/apis.d.ts",
      "import": "./dist/api/apis.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "request": "2.88.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/request": "2.48.12",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
